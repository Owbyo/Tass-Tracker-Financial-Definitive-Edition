{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@tass/db": ["packages/db/src/index.ts"],
      "@tass/domain": ["packages/domain/src/index.ts"],
      "@tass/config": ["packages/config/src/index.ts"]
    }
  }
}
